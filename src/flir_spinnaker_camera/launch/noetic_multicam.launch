<launch>
  <arg name="cameras_file" default="$(find flir_spinnaker_camera)/config/multicam_cameras.yaml" />
  <arg name="camera_info_yaml_path" default="$(env FLIR_ROS_WS)/calibration/flir_camera_info.yaml" />
  <arg name="pixel_format" default="BayerRG16" />
  <arg name="buffer_handling_mode" default="NewestOnly" />
  <arg name="publish_raw" default="false" />
  <arg name="publish_rgb_compressed" default="true" />
  <arg name="rgb_jpeg_quality" default="80" />
  <arg name="publish_extrinsics_tf" default="true" />
  <arg name="extrinsics_yaml_path" default="$(env FLIR_ROS_WS)/calibration/flir_camera_extrinsics.yaml" />

  <node pkg="flir_spinnaker_camera" type="flir_spinnaker_camera_noetic_node" name="flir_multicam" output="screen">
    <param name="cameras_file" value="$(arg cameras_file)" />
    <param name="camera_info_yaml_path" value="$(arg camera_info_yaml_path)" />
    <param name="pixel_format" value="$(arg pixel_format)" />
    <param name="buffer_handling_mode" value="$(arg buffer_handling_mode)" />
    <param name="publish_raw" value="$(arg publish_raw)" />
    <param name="publish_camera_info" value="true" />
    <param name="publish_metadata" value="true" />
    <param name="publish_rgb_compressed" value="$(arg publish_rgb_compressed)" />
    <param name="rgb_compression_format" value="jpeg" />
    <param name="rgb_jpeg_quality" value="$(arg rgb_jpeg_quality)" />
  </node>

  <include if="$(arg publish_extrinsics_tf)" file="$(find flir_spinnaker_camera)/launch/noetic_extrinsics_tf.launch">
    <arg name="extrinsics_yaml_path" value="$(arg extrinsics_yaml_path)" />
  </include>
</launch>
